{
  "installCommand": "npm install",
  "buildCommand": "npm run build -w bidflow-frontend",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/[...path].mjs": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...path]"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}

