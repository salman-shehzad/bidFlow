{
  "installCommand": "npm install",
  "buildCommand": "npm run build --workspace frontend",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/[...path].mjs": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/uploads/(.*)",
      "destination": "/api/uploads/$1"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ]
}
